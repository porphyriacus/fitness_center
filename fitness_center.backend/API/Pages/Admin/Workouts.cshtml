        if (timeInput) {
            let date = new Date(timeInput);
            let hour = date.getHours();
            if (hour < 8 || hour >= 22) {
                showError('Время тренировки должно быть с 8:00 до 22:00');
                e.preventDefault();
                return false;
            }
        }
    });

    $('#prevWeekBtn').click(function() { currentOffset--; renderCalendar(); });
    $('#nextWeekBtn').click(function() { if (currentOffset + 1 > 2) { showError('Расписание доступно только на 2 недели вперёд'); return; } currentOffset++; renderCalendar(); });
    $(document).ready(function() { renderCalendar(); });
</script>