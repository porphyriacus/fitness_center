    function openEditFromDetails() {
        if (currentWorkout) {
            $('#detailsModal').modal('hide');
            document.getElementById('editWorkoutId').value = currentWorkout.id;
            document.getElementById('editName').value = currentWorkout.name;
            document.getElementById('editTrainerId').value = currentWorkout.trainerId;
            let date = new Date(currentWorkout.startsAt);
            let minDateTime = new Date();
            minDateTime.setHours(minDateTime.getHours() + 8);
            document.getElementById('editStartAt').value = date.toISOString().slice(0, 16);
            document.getElementById('editStartAt').min = minDateTime.toISOString().slice(0, 16);
            document.getElementById('editTimeHint').innerHTML = `Нельзя переносить на время раньше чем через 8 часов`;
