    $('#addBookingBtn').click(function() {
        if (currentWorkout) {
            $('#addBookingWorkoutId').val(currentWorkout.id);
            let select = $('#clientSelect');
            select.empty();
            select.append('<option value="">Выберите...</option>');
            if (allClients) {
                // Загружаем актуальный список бронирований
                $.get(`/Admin/Workouts?handler=Bookings&workoutId=${currentWorkout.id}`)
                    .done(function(bookings) {
                        let existingClientIds = bookings.map(b => b.clientId);
                        for (let client of allClients) {
                            if (!existingClientIds.includes(client.id)) {
                                select.append(`<option value="${client.id}">${client.name} ${client.surname}</option>`);
                            }
                        }
                        new bootstrap.Modal(document.getElementById('addBookingModal')).show();
                    })
                    .fail(function() {
                        for (let client of allClients) {
                            select.append(`<option value="${client.id}">${client.name} ${client.surname}</option>`);
                        }
                        new bootstrap.Modal(document.getElementById('addBookingModal')).show();
                    });
            } else {
                new bootstrap.Modal(document.getElementById('addBookingModal')).show();
            }
        }
    });
    $('#addBookingForm').on('submit', function(e) {
        e.preventDefault();
        let form = $(this);
        let submitBtn = form.find('button[type="submit"]');
        submitBtn.prop('disabled', true).text('Запись...');

        $.post('/Admin/Workouts?handler=AddBooking', form.serialize())
            .done(function(response) {
                $('#addBookingModal').modal('hide');
                if (currentWorkout && response.updatedWorkout) {
                    // 1. Обновляем кеш
                    delete bookingsCache[currentWorkout.id];

                    // 2. Обновляем данные в allWorkouts
                    let idx = allWorkouts.findIndex(w => w.id === currentWorkout.id);
                    if (idx !== -1) {
                        allWorkouts[idx] = response.updatedWorkout;
                    }

                    // 3. Обновляем текущую тренировку
                    currentWorkout = response.updatedWorkout;

                    // 4. Обновляем отображение мест в модалке
                    $('#detailsInfo .row:nth-child(5) .col-7').text(`${response.updatedWorkout.currentBookingsCount}/${response.updatedWorkout.defaultMaxCapacity}`);
                    $('#detailsInfo .row:nth-child(6) .col-7').html(`<span class="fw-bold ${response.updatedWorkout.availableSlots > 0 ? 'text-success' : 'text-danger'}">${response.updatedWorkout.availableSlots}</span>`);

                    // 5. Перезагружаем список бронирований
                    loadBookings(currentWorkout.id, true, getWorkoutTypeColor(currentWorkout.workoutTypeId));

                    // 6. Обновляем кнопку записи
                    if (response.updatedWorkout.availableSlots > 0) {
                        $('#addBookingBtn').show();
                    } else {
                        $('#addBookingBtn').hide();
                    }

                    // 7. ПЕРЕРИСОВЫВАЕМ КАЛЕНДАРЬ
                    renderCalendar();
                }
                showSuccess('Клиент успешно записан на тренировку');
            })
            .fail(function(xhr) {
                let errorMsg = xhr.responseJSON?.error || 'Ошибка при записи клиента';
                if (xhr.status === 409) {
                    errorMsg = 'Нет свободных мест или клиент уже записан';
                }
                showError(errorMsg);
            })
            .always(function() {
                submitBtn.prop('disabled', false).text('Записать');
            });
    });

    $('#createForm').on('submit', function(e) {
        let timeInput = $('input[name="StartAt"]', this).val();
        if (timeInput) {
            let date = new Date(timeInput);
            let hour = date.getHours();
            if (hour < 8 || hour >= 22) {
                showError('Время тренировки должно быть с 8:00 до 22:00');
                e.preventDefault();
                return false;
            }
        }
    });

    $('#editForm').on('submit', function(e) {
