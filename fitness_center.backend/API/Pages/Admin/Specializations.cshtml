@page
@model API.Pages.Admin.SpecializationsModel
@{
    ViewData["Title"] = "Управление специализациями";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2" style="color: #2c3e3f;">Специализации</h1>
        <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="fas fa-plus me-2"></i>Добавить специализацию
        </button>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <table class="table table-admin mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Название</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var spec in Model.Specializations)
                    {
                        <tr>
                            <td>@spec.Id</td>
                            <td>@spec.Name</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteSpecialization(@spec.Id, '@spec.Name')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Модалка создания -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title">Добавить специализацию</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                @Html.AntiForgeryToken()
                <div class="modal-body px-4">
                    @if (TempData["CreateError"] != null)
                    {
                        <div class="alert alert-danger">@TempData["CreateError"]</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <input type="text" name="Name" class="form-control" required maxlength="100" />
                        <small class="text-muted">Минимум 2 символа, максимум 100</small>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary rounded-pill">Создать</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Модалка удаления -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title">Удаление специализации</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Delete">
                @Html.AntiForgeryToken()
                <div class="modal-body px-4">
                    <input type="hidden" name="Id" id="deleteId" />
                    <p>Вы уверены, что хотите удалить специализацию <strong id="deleteName"></strong>?</p>
                    <p class="text-danger small">Внимание! Тренеры с этой специализацией останутся, но специализация будет удалена.</p>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-danger rounded-pill">Удалить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
        @if (TempData["CreateError"] != null)
        {
            @:$('#createModal').modal('show');
        }
    });

    function deleteSpecialization(id, name) {
        document.getElementById('deleteId').value = id;
        document.getElementById('deleteName').innerText = name;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
</script>