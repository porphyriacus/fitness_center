@page
@model API.Pages.Admin.ClientsModel
@{
    ViewData["Title"] = "Управление клиентами";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2" style="color: #2c3e3f;">Клиенты</h1>
    </div>

    <!-- Поиск -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <form method="get">
                <div class="row g-3">
                    <div class="col-md-6">
                        <input type="text" name="searchTerm" class="form-control" placeholder="Поиск по имени или фамилии..." value="@(ViewData["SearchTerm"] ?? "")" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100 rounded-pill">Найти</button>
                    </div>
                    <div class="col-md-2">
                        <a href="/Admin/Clients" class="btn btn-outline-secondary w-100 rounded-pill">Сбросить</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <table class="table table-admin mb-0">
                <thead>
                    <tr>
                        <th><a href="#" class="sort-link text-decoration-none" data-sort="Id">ID</a></th>
                        <th><a href="#" class="sort-link text-decoration-none" data-sort="Name">Имя</a></th>
                        <th><a href="#" class="sort-link text-decoration-none" data-sort="Surname">Фамилия</a></th>
                        <th><a href="#" class="sort-link text-decoration-none" data-sort="RegisteredAt">Дата регистрации</a></th>
                        <th>Фото</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Clients?.Items != null && Model.Clients.Items.Any())
                    {
                        @foreach (var client in Model.Clients.Items)
                        {
                            <tr>
                                <td>@client.Id</td>
                                <td>@client.Name</td>
                                <td>@client.Surname</td>
                                <td>@client.RegisteredAt.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(client.ProfilePhotoUrl))
                                    {
                                        <img src="@client.ProfilePhotoUrl" style="width: 40px; height: 40px; object-fit: cover; border-radius: 50%;" />
                                    }
                                    else
                                    {
                                        <i class="fas fa-user-circle fa-2x text-muted"></i>
                                    }
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn btn-sm btn-outline-success" onclick="manageMembership(@client.Id, '@client.Name')" title="Управление абонементом">
                                            <i class="fas fa-ticket-alt"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-primary" onclick='editClient(@client.Id, "@client.Name", "@client.Surname", "@client.ProfilePhotoUrl")' title="Редактировать">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteClient(@client.Id, '@client.Name')" title="Удалить">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Клиенты не найдены</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Пагинация -->
    @if (Model.Clients != null && Model.Clients.TotalPages > 1)
    {
        var currentPage = Model.Clients.PageNumber;
        var totalPages = Model.Clients.TotalPages;
        var searchTerm = ViewData["SearchTerm"]?.ToString() ?? "";
        var pageSize = ViewData["PageSize"]?.ToString() ?? "10";
        var sortBy = ViewData["SortBy"]?.ToString() ?? "Id";
        var sortDescending = ViewData["SortDescending"]?.ToString() == "true";

        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.Clients.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="?pageNumber=@(currentPage - 1)&pageSize=@pageSize&searchTerm=@searchTerm&sortBy=@sortBy&sortDescending=@sortDescending.ToString().ToLower()">&laquo;</a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled"><span class="page-link">&laquo;</span></li>
                }

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="?pageNumber=@i&pageSize=@pageSize&searchTerm=@searchTerm&sortBy=@sortBy&sortDescending=@sortDescending.ToString().ToLower()">@i</a>
                    </li>
                }

                @if (Model.Clients.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="?pageNumber=@(currentPage + 1)&pageSize=@pageSize&searchTerm=@searchTerm&sortBy=@sortBy&sortDescending=@sortDescending.ToString().ToLower()">&raquo;</a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled"><span class="page-link">&raquo;</span></li>
                }
            </ul>
            <div class="text-center text-muted small">
                Страница @currentPage из @totalPages (всего @Model.Clients.TotalCount записей)
            </div>
        </nav>
    }
</div>
<!-- Модалка редактирования -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title">Редактировать клиента</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Update">
                @Html.AntiForgeryToken()
                <div class="modal-body px-4">
                    @if (TempData["EditError"] != null)
                    {
                        <div class="alert alert-danger">@TempData["EditError"]</div>
                    }
                    <input type="hidden" name="Id" id="editId" />
                    <div class="mb-3">
                        <label class="form-label">Имя</label>
                        <input type="text" name="Name" id="editName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Фамилия</label>
                        <input type="text" name="Surname" id="editSurname" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">URL фото</label>
                        <input type="text" name="ProfilePhotoUrl" id="editPhotoUrl" class="form-control" placeholder="https://..." />
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary rounded-pill">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Модалка удаления -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title">Удаление клиента</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Delete">
                @Html.AntiForgeryToken()
                <div class="modal-body px-4">
                    <input type="hidden" name="Id" id="deleteId" />
                    <p>Вы уверены, что хотите удалить клиента <strong id="deleteName"></strong>?</p>
                    <p class="text-danger small">Все записи и абонементы клиента также будут удалены.</p>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-danger rounded-pill">Удалить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Модалка управления абонементом -->
<div class="modal fade" id="membershipModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title" id="membershipModalTitle">Управление абонементом</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <div id="membershipInfo"></div>
                <div class="mt-3" id="membershipActions"></div>
            </div>
        </div>
    </div>
</div>

<!-- Модалка назначения абонемента -->
<div class="modal fade" id="assignMembershipModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title">Назначить абонемент</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="AssignMembership">
                @Html.AntiForgeryToken()
                <div class="modal-body px-4">
                    <input type="hidden" name="ClientId" id="assignClientId" />
                    <div class="mb-3">
                        <label class="form-label">Тип абонемента</label>
                        <select name="MembershipTypeId" id="membershipTypeId" class="form-select" required>
                            <option value="">Выберите...</option>
                            @foreach (var type in Model.MembershipTypes)
                            {
                                <option value="@type.Id">
                                    @type.Name - @type.Price руб.
                                    (@(type.SessionsCount.HasValue ? type.SessionsCount + " занятий" : "Безлимит"), @type.ValidityDays дней)
                                </option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary rounded-pill">Назначить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Модалка заморозки -->
<div class="modal fade" id="freezeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title">Заморозить абонемент</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="FreezeMembership">
                @Html.AntiForgeryToken()
                <div class="modal-body px-4">
                    <input type="hidden" name="ClientId" id="freezeClientId" />
                    <div class="mb-3">
                        <label class="form-label">Количество дней заморозки</label>
                        <input type="number" name="Days" id="freezeDays" class="form-control" required min="1" />
                        <small class="text-muted" id="freezeDaysHint"></small>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary rounded-pill">Заморозить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Модалка подтверждения действия -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title" id="confirmTitle">Подтверждение</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <p id="confirmMessage"></p>
            </div>
            <div class="modal-footer border-0 pb-4 px-4">
                <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-primary rounded-pill" id="confirmOk">Да</button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
        @if (TempData["EditError"] != null)
        {
            @:$('#editModal').modal('show');
        }
        @if (TempData["MembershipError"] != null)
        {
            @:alert('@TempData["MembershipError"]');
        }
    });

    function editClient(id, name, surname, photoUrl) {
        document.getElementById('editId').value = id;
        document.getElementById('editName').value = name;
        document.getElementById('editSurname').value = surname;
        document.getElementById('editPhotoUrl').value = photoUrl || '';
        new bootstrap.Modal(document.getElementById('editModal')).show();
    }

    function deleteClient(id, name) {
        showConfirm(`Вы уверены, что хотите удалить клиента "${name}"?`, function() {
            $.post('/Admin/Clients?handler=Delete', { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() })
                .done(function() { location.reload(); })
                .fail(function(xhr) { alert(xhr.responseJSON?.error || 'Ошибка'); });
        });
    }

    function showConfirm(message, onOk) {
        $('#confirmMessage').text(message);
        $('#confirmModal').modal('show');
        $('#confirmOk').off('click').on('click', function() {
            $('#confirmModal').modal('hide');
            onOk();
        });
    }

    function manageMembership(clientId, clientName) {
        $('#membershipModalTitle').text(`Абонемент: ${clientName}`);
        $('#membershipInfo').html('<div class="text-center py-3">Загрузка...</div>');
        $('#membershipActions').html('');
        $('#membershipModal').modal('show');

        $.get(`/Admin/Clients?handler=Membership&clientId=${clientId}`)
            .done(function(data) {
                if (data && data.id) {
                    let statusText = data.statusText;
                    let statusColor = data.statusColor;
                    let totalSessionsText = data.isUnlimited ? 'Безлимит' : `${data.sessionsCount} занятий всего`;
                    let leftSessionsText = data.isUnlimited ? 'Безлимит' : `${data.sessionsLeft} занятий осталось`;
                    let expireText = '';
                    if (data.expireDate) {
                        expireText = new Date(data.expireDate).toLocaleDateString();
                    } else if (data.activatedDate) {
                        expireText = 'Срок не установлен';
                    } else {
                        expireText = 'Не активирован (активируется при первом посещении)';
                    }

                    let html = `
                        <div class="alert alert-${statusColor} text-center">${statusText}</div>
                        <div class="row mb-2">
                            <div class="col-5 text-muted">Тип:</div>
                            <div class="col-7">${data.membershipTypeName}</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 text-muted">Всего занятий:</div>
                            <div class="col-7">${totalSessionsText}</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 text-muted">Осталось занятий:</div>
                            <div class="col-7">${leftSessionsText}</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 text-muted">Срок действия:</div>
                            <div class="col-7">${data.validityDays} дней</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 text-muted">Действует до:</div>
                            <div class="col-7">${expireText}</div>
                        </div>
                    `;
                    if (data.canFreeze && data.maxFreezeDays) {
                        html += `<div class="row mb-2">
                            <div class="col-5 text-muted">Заморозка:</div>
                            <div class="col-7">до ${data.maxFreezeDays} дней</div>
                        </div>`;
                    }
                    $('#membershipInfo').html(html);

                    let actions = '';

                    // Заморозка (активен, не заморожен, не закончен)
                    if (!data.isFinished && !data.isFrozen && data.activatedDate && data.canFreeze && data.maxFreezeDays && !data.freezeUsed) {
                        actions += `<button class="btn btn-primary w-100 mb-2 rounded-pill" onclick="openFreezeModal(${clientId}, ${data.maxFreezeDays})">Заморозить (до ${data.maxFreezeDays} дней)</button>`;
                    } else if (!data.isFinished && !data.isFrozen && data.activatedDate && data.freezeUsed) {
                        // Заморозка уже была использована
                        actions += `<div class="alert alert-secondary text-center">Заморозка уже использована</div>`;
                    }
                    // Разморозка (для всех замороженных)
                    if (data.isFrozen) {
                        actions += `<button class="btn btn-primary w-100 mb-2 rounded-pill" onclick="unfreezeMembership(${clientId})">Разморозить</button>`;
                    }

                    $('#membershipActions').html(actions);
                } else {
                    $('#membershipInfo').html('<div class="alert alert-info text-center">Нет активного абонемента</div>');
                    $('#membershipActions').html(`<button class="btn btn-primary w-100 rounded-pill" onclick="openAssignModal(${clientId})">Назначить абонемент</button>`);
                }

            })
            .fail(function() {
                $('#membershipInfo').html('<div class="alert alert-danger">Ошибка загрузки</div>');
            });
    }

    function unfreezeMembership(clientId) {
        showConfirm('Разморозить абонемент?', function() {
            $.post('/Admin/Clients?handler=UnfreezeMembership', { clientId: clientId, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() })
                .done(function() { location.reload(); })
                .fail(function(xhr) { alert(xhr.responseJSON?.error || 'Ошибка'); });
        });
    }

    function openAssignModal(clientId) {
        $('#membershipModal').modal('hide');
        $('#assignClientId').val(clientId);
        $('#assignMembershipModal').modal('show');
    }

    function openFreezeModal(clientId, maxDays) {
        $('#membershipModal').modal('hide');
        $('#freezeClientId').val(clientId);
        $('#freezeDays').attr('max', maxDays);
        $('#freezeDaysHint').text(`Максимум ${maxDays} дней (согласно типу абонемента)`);
        $('#freezeDays').val(1);
        $('#freezeModal').modal('show');
    }

    // Сортировка
    $('.sort-link').click(function(e) {
        e.preventDefault();
        let sortBy = $(this).data('sort');
        let currentUrl = new URL(window.location.href);
        currentUrl.searchParams.set('sortBy', sortBy);
        let currentDesc = currentUrl.searchParams.get('sortDescending') === 'true';
        currentUrl.searchParams.set('sortDescending', !currentDesc);
        window.location.href = currentUrl.toString();
    });
</script>