@page
@{
    ViewData["Title"] = "Главная";
}

<div class="text-center mb-5">
    <h1 class="display-5 fw-bold" style="color: #2c3e3f;">Добро пожаловать в PrimeSport</h1>
    <p class="lead text-muted">Управление фитнес-клубом – просто и удобно.</p>
    <hr class="my-4" style="width: 60px; margin: 0 auto; border-color: #67a69b; border-width: 2px;" />
    <p class="mt-4">Записывайтесь на тренировки, отслеживайте прогресс, управляйте абонементами.</p>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
    <div class="col text-center">
        <div class="p-4 rounded-4 bg-white shadow-sm">
            <i class="fas fa-heartbeat fa-3x" style="color: #67a69b;"></i>
            <h4 class="mt-3" style="color: #2c3e3f;">Современные тренировки</h4>
            <p class="text-muted">Разнообразные групповые и индивидуальные занятия.</p>
        </div>
    </div>
    <div class="col text-center">
        <div class="p-4 rounded-4 bg-white shadow-sm">
            <i class="fas fa-calendar-alt fa-3x" style="color: #67a69b;"></i>
            <h4 class="mt-3" style="color: #2c3e3f;">Удобное расписание</h4>
            <p class="text-muted">Онлайн-запись и отмена записей.</p>
        </div>
    </div>
    <div class="col text-center">
        <div class="p-4 rounded-4 bg-white shadow-sm">
            <i class="fas fa-chart-simple fa-3x" style="color: #67a69b;"></i>
            <h4 class="mt-3" style="color: #2c3e3f;">Контроль прогресса</h4>
            <p class="text-muted">История посещений, абонементы, статистика.</p>
        </div>
    </div>
</div>